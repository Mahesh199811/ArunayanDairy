<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:ArunayanDairy.ViewModels"
             x:Class="ArunayanDairy.Views.LoginPage"
             x:DataType="viewModels:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Primary}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Center">

            <!-- Logo/App Name -->
            <Label Text="Arunayan Dairy"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="White"
                   Margin="0,40,0,20"/>

            <!-- Login Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="24">

                <VerticalStackLayout Spacing="16">

                    <Label Text="Welcome Back"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}"/>

                    <Label Text="Sign in to continue"
                           FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Gray600}"
                           Margin="0,0,0,16"/>

                    <!-- Email Entry -->
                    <Label Text="Email"
                           FontSize="14"
                           TextColor="{StaticResource Gray900}"/>
                    <Frame BorderColor="{StaticResource Gray300}"
                           CornerRadius="8"
                           Padding="0"
                           HasShadow="False">
                        <Entry Text="{Binding Email}"
                               Placeholder="Enter your email"
                               Keyboard="Email"
                               ReturnType="Next"
                               TextColor="{StaticResource Gray900}"
                               PlaceholderColor="{StaticResource Gray400}"/>
                    </Frame>

                    <!-- Password Entry -->
                    <Label Text="Password"
                           FontSize="14"
                           TextColor="{StaticResource Gray900}"
                           Margin="0,8,0,0"/>
                    <Frame BorderColor="{StaticResource Gray300}"
                           CornerRadius="8"
                           Padding="0"
                           HasShadow="False">
                        <Entry Text="{Binding Password}"
                               Placeholder="Enter your password"
                               IsPassword="True"
                               ReturnType="Done"
                               TextColor="{StaticResource Gray900}"
                               PlaceholderColor="{StaticResource Gray400}"/>
                    </Frame>

                    <!-- Error Message -->
                    <Label Text="{Binding ErrorMessage}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                           TextColor="Red"
                           FontSize="12"
                           HorizontalOptions="Center"
                           Margin="0,8,0,0"/>

                    <!-- Login Button -->
                    <Button Text="Sign In"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="50"
                            Margin="0,16,0,0"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                        Binding="{Binding IsBusy}"
                                        Value="True">
                                <Setter Property="Text" Value="Signing in..."/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <!-- Forgot Password -->
                    <Label Text="Forgot Password?"
                           FontSize="14"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           Margin="0,8,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToSignupCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Sign Up Link -->
                    <HorizontalStackLayout HorizontalOptions="Center"
                                          Spacing="4"
                                          Margin="0,16,0,0">
                        <Label Text="Don't have an account?"
                               FontSize="14"
                               TextColor="{StaticResource Gray600}"/>
                        <Label Text="Sign Up"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding NavigateToSignupCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                              IsVisible="{Binding IsBusy}"
                              Color="White"
                              Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
