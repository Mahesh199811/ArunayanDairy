<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ArunayanDairy.ViewModels"
             xmlns:models="clr-namespace:ArunayanDairy.Models"
             x:Class="ArunayanDairy.Views.ProductListPage"
             x:DataType="viewmodels:ProductListViewModel"
             Title="{Binding Title}">
    
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
        
        <!-- Error Message -->
        <Frame Grid.Row="0" 
               BackgroundColor="#FFE6E6" 
               Padding="10" 
               Margin="10,5"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}">
            <Label Text="{Binding ErrorMessage}" 
                   TextColor="Red" 
                   FontSize="14" />
        </Frame>

        <!-- Search Bar -->
        <SearchBar Grid.Row="1"
                   Placeholder="Search products..."
                   Text="{Binding SearchText}"
                   Margin="10,5" />

        <!-- Filters -->
        <Grid Grid.Row="2" 
              ColumnDefinitions="*,*,Auto" 
              Margin="10,5"
              ColumnSpacing="10">
            
            <Picker Grid.Column="0"
                    Title="Select Vendor"
                    ItemsSource="{Binding Vendors}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedVendor}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" />
            
            <Picker Grid.Column="1"
                    Title="Category"
                    ItemsSource="{Binding Categories}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCategory}" />

            <DatePicker Grid.Column="2"
                        Date="{Binding SelectedDate}"
                        Format="MMM dd" />
        </Grid>

        <!-- Products List -->
        <RefreshView Grid.Row="3"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding FilteredProducts}"
                           SelectionMode="None">
                <CollectionView.EmptyView>
                    <StackLayout Padding="20" VerticalOptions="Center">
                        <Label Text="No products available"
                               FontSize="18"
                               TextColor="Gray"
                               HorizontalOptions="Center" />
                        <Label Text="Try changing filters"
                               FontSize="14"
                               TextColor="Gray"
                               HorizontalOptions="Center"
                               Margin="0,5,0,0" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Product">
                        <Frame Margin="10,5" 
                               Padding="10" 
                               CornerRadius="8"
                               HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ProductListViewModel}}, Path=ProductTappedCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                                <!-- Product Image -->
                                <Frame Grid.Column="0" 
                                       Padding="0" 
                                       CornerRadius="8"
                                       IsClippedToBounds="True"
                                       HeightRequest="80"
                                       WidthRequest="80">
                                    <Image Source="{Binding ImageUrl, TargetNullValue='dotnet_bot.png'}"
                                           Aspect="AspectFill" />
                                </Frame>

                                <!-- Product Info -->
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <Label Text="{Binding Name}" 
                                           FontSize="16" 
                                           FontAttributes="Bold" />
                                    <Label Text="{Binding CategoryName}" 
                                           FontSize="12" 
                                           TextColor="Gray" />
                                    <Label FontSize="14" 
                                           TextColor="#2196F3"
                                           FontAttributes="Bold">
                                        <Label.Text>
                                            <MultiBinding StringFormat="₹{0:F2}/{1}">
                                                <Binding Path="BasePrice" />
                                                <Binding Path="Unit" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label FontSize="12" TextColor="Gray">
                                        <Label.Text>
                                            <MultiBinding StringFormat="Min: {0} {1}">
                                                <Binding Path="MinOrderQuantity" />
                                                <Binding Path="Unit" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </VerticalStackLayout>

                                <!-- Add to Cart Button -->
                                <Button Grid.Column="2"
                                        Text="+"
                                        FontSize="20"
                                        WidthRequest="45"
                                        HeightRequest="45"
                                        CornerRadius="22"
                                        BackgroundColor="#4CAF50"
                                        TextColor="White"
                                        VerticalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ProductListViewModel}}, Path=AddToCartCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Cart Footer -->
        <Frame Grid.Row="4" 
               BackgroundColor="#2196F3" 
               Padding="15" 
               CornerRadius="0"
               IsVisible="{Binding CartItemCount, Converter={StaticResource IntToBoolConverter}}">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ViewCartCommand}" />
            </Frame.GestureRecognizers>

            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0">
                    <Label TextColor="White" FontSize="14">
                        <Label.Text>
                            <MultiBinding StringFormat="{}{0} items">
                                <Binding Path="CartItemCount" />
                            </MultiBinding>
                        </Label.Text>
                    </Label>
                    <Label TextColor="White" FontSize="18" FontAttributes="Bold">
                        <Label.Text>
                            <MultiBinding StringFormat="₹{0:F2}">
                                <Binding Path="CartTotal" />
                            </MultiBinding>
                        </Label.Text>
                    </Label>
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="View Cart"
                        BackgroundColor="White"
                        TextColor="#2196F3"
                        CornerRadius="8"
                        Command="{Binding ViewCartCommand}" />
            </Grid>
        </Frame>

    </Grid>
</ContentPage>
