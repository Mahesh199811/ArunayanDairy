<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ArunayanDairy.ViewModels"
             xmlns:models="clr-namespace:ArunayanDairy.Models"
             x:Class="ArunayanDairy.Views.AdminDashboardPage"
             x:DataType="viewmodels:AdminDashboardViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">
            
            <!-- Error Message -->
            <Frame BackgroundColor="#FFE6E6" 
                   Padding="10"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}">
                <Label Text="{Binding ErrorMessage}" 
                       TextColor="Red" 
                       FontSize="14" />
            </Frame>

            <!-- Statistics Cards -->
            <Label Text="Statistics" 
                   FontSize="20" 
                   FontAttributes="Bold"
                   Margin="0,0,0,10" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                
                <!-- Total Orders -->
                <Frame Grid.Row="0" Grid.Column="0" 
                       Padding="15" 
                       BackgroundColor="#2196F3"
                       CornerRadius="12">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Total Orders" 
                               TextColor="White" 
                               FontSize="14" />
                        <Label Text="{Binding TotalOrders}" 
                               TextColor="White" 
                               FontSize="28" 
                               FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Pending Orders -->
                <Frame Grid.Row="0" Grid.Column="1" 
                       Padding="15" 
                       BackgroundColor="#FF9800"
                       CornerRadius="12">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Pending" 
                               TextColor="White" 
                               FontSize="14" />
                        <Label Text="{Binding PendingOrders}" 
                               TextColor="White" 
                               FontSize="28" 
                               FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Confirmed Orders -->
                <Frame Grid.Row="1" Grid.Column="0" 
                       Padding="15" 
                       BackgroundColor="#4CAF50"
                       CornerRadius="12">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Confirmed" 
                               TextColor="White" 
                               FontSize="14" />
                        <Label Text="{Binding ConfirmedOrders}" 
                               TextColor="White" 
                               FontSize="28" 
                               FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Today Revenue -->
                <Frame Grid.Row="1" Grid.Column="1" 
                       Padding="15" 
                       BackgroundColor="#9C27B0"
                       CornerRadius="12">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Today Revenue" 
                               TextColor="White" 
                               FontSize="14" />
                        <Label FontSize="20" 
                               FontAttributes="Bold"
                               TextColor="White">
                            <Label.Text>
                                <MultiBinding StringFormat="₹{0:F2}">
                                    <Binding Path="TodayRevenue" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- Quick Actions -->
            <Label Text="Quick Actions" 
                   FontSize="20" 
                   FontAttributes="Bold"
                   Margin="0,10,0,10" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="Manage Products"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        HeightRequest="50"
                        CornerRadius="10"
                        Command="{Binding ManageProductsCommand}" />

                <Button Grid.Column="1"
                        Text="Manage Categories"
                        BackgroundColor="#FF5722"
                        TextColor="White"
                        HeightRequest="50"
                        CornerRadius="10"
                        Command="{Binding ManageCategoriesCommand}" />
            </Grid>

            <!-- Status Filter -->
            <Picker Title="Filter by Status"
                    ItemsSource="{Binding StatusFilters}"
                    SelectedItem="{Binding SelectedStatusFilter}"
                    Margin="0,10,0,0" />

            <!-- Recent Orders -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Recent Orders" 
                       FontSize="20" 
                       FontAttributes="Bold"
                       Margin="0,10,0,10" />
                
                <Button Grid.Column="1"
                        Text="Refresh"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="8"
                        Command="{Binding RefreshCommand}"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />

                <ActivityIndicator Grid.Column="1"
                                 IsRunning="{Binding IsBusy}"
                                 IsVisible="{Binding IsBusy}"
                                 Color="#4CAF50" />
            </Grid>

            <!-- Orders List -->
            <CollectionView ItemsSource="{Binding FilteredOrders}"
                           SelectionMode="None"
                           EmptyView="No orders found">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Order">
                        <Frame Padding="15" 
                               Margin="0,5" 
                               CornerRadius="8"
                               HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AdminDashboardViewModel}}, Path=OrderTappedCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                
                                <!-- Order Number and Status -->
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding OrderNumber}" 
                                           FontSize="18" 
                                           FontAttributes="Bold" />
                                    <Frame Grid.Column="1"
                                           Padding="8,4"
                                           CornerRadius="12"
                                           HasShadow="False"
                                           Margin="0,0,10,0">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame" Binding="{Binding Status}" Value="Pending">
                                                <Setter Property="BackgroundColor" Value="#FFF3E0" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Frame" Binding="{Binding Status}" Value="Confirmed">
                                                <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Frame" Binding="{Binding Status}" Value="Processing">
                                                <Setter Property="BackgroundColor" Value="#E8F5E9" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Frame" Binding="{Binding Status}" Value="Delivered">
                                                <Setter Property="BackgroundColor" Value="#C8E6C9" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Frame" Binding="{Binding Status}" Value="Cancelled">
                                                <Setter Property="BackgroundColor" Value="#FFCDD2" />
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <Label Text="{Binding Status}" 
                                               FontSize="12" 
                                               FontAttributes="Bold" />
                                    </Frame>
                                    <Button Grid.Column="2"
                                            Text="Update"
                                            FontSize="12"
                                            Padding="10,5"
                                            BackgroundColor="#2196F3"
                                            TextColor="White"
                                            CornerRadius="8"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AdminDashboardViewModel}}, Path=UpdateOrderStatusCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>

                                <!-- Customer Info -->
                                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="5">
                                    <Label Grid.Column="0"
                                           Text="Customer:"
                                           FontSize="14"
                                           TextColor="Gray" />
                                    <Label Grid.Column="1"
                                           Text="{Binding CustomerName}"
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                </Grid>

                                <!-- Dates -->
                                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="Order Date"
                                               FontSize="12"
                                               TextColor="Gray" />
                                        <Label Text="{Binding OrderDate, StringFormat='{0:MMM dd, yyyy}'}"
                                               FontSize="14" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1">
                                        <Label Text="Delivery Date"
                                               FontSize="12"
                                               TextColor="Gray" />
                                        <Label Text="{Binding DeliveryDate, StringFormat='{0:MMM dd, yyyy}'}"
                                               FontSize="14"
                                               TextColor="#2196F3"
                                               FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Amount and Items -->
                                <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           FontSize="14"
                                           TextColor="Gray">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} items">
                                                <Binding Path="Items.Count" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                    <Label Grid.Column="1"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#4CAF50">
                                        <Label.Text>
                                            <MultiBinding StringFormat="₹{0:F2}">
                                                <Binding Path="TotalAmount" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </Grid>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
