<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ArunayanDairy.ViewModels"
             xmlns:models="clr-namespace:ArunayanDairy.Models"
             x:Class="ArunayanDairy.Views.OrderDetailPage"
             x:DataType="viewmodels:OrderDetailViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">
            
            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                             IsVisible="{Binding IsBusy}"
                             Color="#2196F3"
                             Margin="20" />

            <!-- Error Message -->
            <Frame BackgroundColor="#FFE6E6" 
                   Padding="10"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}">
                <Label Text="{Binding ErrorMessage}" 
                       TextColor="Red" 
                       FontSize="14" />
            </Frame>

            <VerticalStackLayout IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                               Spacing="15">
                
                <!-- Order Header -->
                <Frame Padding="15" 
                       BackgroundColor="White"
                       HasShadow="True"
                       CornerRadius="8">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                        
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="{Binding Order.OrderNumber}" 
                                   FontSize="20" 
                                   FontAttributes="Bold" />
                            <Frame Grid.Column="1"
                                   Padding="10,5"
                                   CornerRadius="15"
                                   HasShadow="False">
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Order.Status}" Value="Pending">
                                        <Setter Property="BackgroundColor" Value="#FFF3E0" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Order.Status}" Value="Confirmed">
                                        <Setter Property="BackgroundColor" Value="#E3F2FD" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Order.Status}" Value="Processing">
                                        <Setter Property="BackgroundColor" Value="#E8F5E9" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Order.Status}" Value="Delivered">
                                        <Setter Property="BackgroundColor" Value="#C8E6C9" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding Order.Status}" Value="Cancelled">
                                        <Setter Property="BackgroundColor" Value="#FFCDD2" />
                                    </DataTrigger>
                                </Frame.Triggers>
                                <Label Text="{Binding Order.Status}" 
                                       FontSize="14" 
                                       FontAttributes="Bold" />
                            </Frame>
                        </Grid>

                        <BoxView Grid.Row="1" 
                                 HeightRequest="1" 
                                 Color="#E0E0E0" />

                        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="5">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Ordered:"
                                   FontSize="14"
                                   TextColor="Gray" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Order.OrderDate, StringFormat='{0:MMMM dd, yyyy hh:mm tt}'}"
                                   FontSize="14"
                                   FontAttributes="Bold" />

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Delivery:"
                                   FontSize="14"
                                   TextColor="Gray" />
                            <Label Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Order.DeliveryDate, StringFormat='{0:MMMM dd, yyyy}'}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#2196F3" />
                        </Grid>

                        <Label Grid.Row="3"
                               Text="{Binding Order.Notes}"
                               FontSize="14"
                               TextColor="Gray"
                               IsVisible="{Binding Order.Notes, Converter={StaticResource StringToBoolConverter}}" />

                    </Grid>
                </Frame>

                <!-- Order Items -->
                <Label Text="Order Items" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       Margin="5,0" />

                <CollectionView ItemsSource="{Binding Order.Items}"
                               SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OrderItem">
                            <Frame Padding="12" 
                                   Margin="0,5" 
                                   CornerRadius="8"
                                   HasShadow="True">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="5">
                                    
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding ProductName}" 
                                           FontSize="16" 
                                           FontAttributes="Bold" />

                                    <Label Grid.Row="0" Grid.Column="1"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="#4CAF50">
                                        <Label.Text>
                                            <MultiBinding StringFormat="₹{0:F2}">
                                                <Binding Path="Subtotal" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>

                                    <Label Grid.Row="1" Grid.Column="0"
                                           FontSize="14"
                                           TextColor="Gray">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} {1} × ₹{2:F2}">
                                                <Binding Path="Quantity" />
                                                <Binding Path="ProductUnit" />
                                                <Binding Path="UnitPrice" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>

                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Order Summary -->
                <Frame Padding="15" 
                       BackgroundColor="#E8F5E9"
                       CornerRadius="8"
                       Margin="0,10,0,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Total Amount"
                               FontSize="20"
                               FontAttributes="Bold" />
                        <Label Grid.Column="1"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#4CAF50">
                            <Label.Text>
                                <MultiBinding StringFormat="₹{0:F2}">
                                    <Binding Path="Order.TotalAmount" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </Grid>
                </Frame>

                <!-- Cancel Order Button -->
                <Button Text="Cancel Order"
                        FontSize="16"
                        BackgroundColor="#FF5722"
                        TextColor="White"
                        HeightRequest="50"
                        CornerRadius="10"
                        Command="{Binding CancelOrderCommand}"
                        IsVisible="{Binding CanCancel}"
                        Margin="0,10,0,20" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
